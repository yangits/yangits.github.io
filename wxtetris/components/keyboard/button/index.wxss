.button {
    text-align: center;
    color: #111;
    position: absolute;
    white-space: nowrap;
    line-height: 1.6;
}

.button.s2 {
    font-size: 16px;
}

.button ._span.position {
    position: absolute;
    top: 5px;
    left: 102px;
}

.button ._i {
    display: block;
    position: relative;
    border: 1px solid #000;
    border-radius: 50%;
    box-shadow: 0 3px 3px rgba(0,0,0,0.2);
}

.button ._i:before,.button ._i:after {
    content: '';
    display: block;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    border-radius: 50%;
    box-shadow: 0 5px 10px rgba(255,255,255,0.8) inset;
}

.button ._i:after {
    box-shadow: 0 -5px 10px rgba(0,0,0,0.8) inset;
}

.button ._i.active:before {
    box-shadow: 0 -3px 6px rgba(255,255,255,0.6) inset;
}

.button ._i.active:after {
    box-shadow: 0 5px 5px rgba(0,0,0,0.6) inset;
}

.button.blue ._i {
    background: #5a65f1;
}

.button.green ._i {
    background: #2dc421;
}

.button.red ._i {
    background: #dd1a1a;
}

.button.s0 ._i {
    width: 160px;
    height: 160px;
}

.button.s1 ._i {
    width: 100px;
    height: 100px;
}

.button.s2 ._i {
    width: 52px;
    height: 52px;
    box-shadow: 1px 1px 1px rgba(0,0,0,0.2);
}

.button.s2 ._i:before,.button.s2 ._i:after {
    box-shadow: 0px 3px 6px rgba(255,255,255,0.8) inset;
}

.button.s2 ._i:after {
    box-shadow: 0px -3px 6px rgba(0,0,0,0.8) inset;
}

.button.s2 ._i.active:before {
    box-shadow: 0px -1px 2px rgba(255,255,255,0.6) inset;
}

.button.s2 ._i.active:after {
    box-shadow: 0px 3px 3px rgba(0,0,0,0.7) inset;
}

.button.s1 ._em {
    display: block;
    width: 0;
    height: 0;
    border: 8px solid;
    border-color: transparent transparent #111;
    position: absolute;
    top: 50%;
    left: 50%;
    margin: -12px 0 0 -8px;
}